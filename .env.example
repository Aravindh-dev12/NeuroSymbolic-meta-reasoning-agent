# NeuroSymbolic AGI Agent - Environment Configuration Example
# Copy this file to .env and configure your settings

# ============================================
# LLM Backend Configuration
# ============================================

# Backend type: local, anthropic, or openai
LLM_BACKEND=local

# Local LLM configuration (when LLM_BACKEND=local)
LOCAL_MODEL_NAME=auto
ALLOW_HEURISTIC_FALLBACK=true

# Available local models:
# - auto (prefers running Ollama, otherwise llama.cpp)
# - agentic-rules (offline structured fallback; no external model)
# - ollama-qwen2.5 (Ollama qwen2.5:7b)
# - ollama-llama3.1 (Ollama llama3.1:8b)
# - ollama-deepseek-r1 (Ollama deepseek-r1:7b)
# - ollama-mistral (Ollama mistral:7b)
# - ollama-phi4-mini (Ollama phi4-mini)
# - transformers-qwen2.5-0.5b (Hugging Face Transformers)
# - transformers-tinyllama (Hugging Face Transformers)
# - llama3-8b (Meta Llama 3 8B, ~4.7GB)
# - llama3-70b (Meta Llama 3 70B, ~39GB)
# - mistral-7b (Mistral 7B, ~4.3GB)
# - mixtral-8x7b (Mixtral 8x7B, ~26GB)
# - ollama-llama3 (requires Ollama)

# Anthropic Claude configuration (when LLM_BACKEND=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI configuration (when LLM_BACKEND=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ============================================
# Agent Configuration
# ============================================

# Confidence threshold for routing decisions (0.0 to 1.0)
CONFIDENCE_THRESHOLD=0.75

# Maximum self-improvement rounds
MAX_SELF_IMPROVEMENT_ROUNDS=3

# Maximum planning depth for hierarchical tasks
MAX_PLANNING_DEPTH=5

# Enable verbose output
VERBOSE=true

# Enable telemetry and performance tracking
ENABLE_TELEMETRY=true

# ============================================
# Memory Configuration
# ============================================

# Vector database type: chroma, faiss, or sqlite
VECTOR_DB_TYPE=sqlite

# Directory for vector database persistence
VECTOR_DB_DIR=data/vector_db

# Enable memory compression
ENABLE_MEMORY_COMPRESSION=true

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable console logging
LOG_TO_CONSOLE=true

# ============================================
# Neural Configuration
# ============================================

# Device for neural operations: cpu or cuda
NEURAL_DEVICE=cpu

# Classifier hidden dimension
CLASSIFIER_HIDDEN_DIM=256

# Batch size for neural operations
BATCH_SIZE=32

# ============================================
# Symbolic Configuration
# ============================================

# Symbolic solver: z3
SYMBOLIC_SOLVER=z3

# Timeout for symbolic solving (seconds)
SYMBOLIC_TIMEOUT=10

# Maximum iterations for symbolic solving
SYMBOLIC_MAX_ITERATIONS=1000

# ============================================
# Constitutional Configuration
# ============================================

# Maximum constitutional violations before halting
MAX_CONSTITUTIONAL_VIOLATIONS=2

# Enable strict constitutional mode
CONSTITUTIONAL_STRICT_MODE=false
